# Порт приложения
PORT=3000

# Секрет для JWT (используется для подписи токенов)
JWT_SECRET=super_secure_jwt_secret

# Данные для подключения к базе данных PostgreSQL
DATABASE_URL=postgres://username:password@localhost:5432/notes_db

# OAuth параметры для GitHub (оставьте пустыми, если не используете)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# OAuth параметры для Google (оставьте пустыми, если не используете)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth параметры для Facebook (оставьте пустыми, если не используете)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
